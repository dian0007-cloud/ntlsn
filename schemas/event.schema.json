{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NTLSN Event",
  "type": "object",
  "required": ["id", "title", "uni", "date", "type", "desc", "verified"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "integer", "description": "Unique. Use 100+ for new entries (1–99 are taken)." },
    "title": { "type": "string", "minLength": 1 },
    "uni": { "type": "string", "description": "University id from universities.json, or 'national' for sector-wide events." },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "endDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "description": "Optional; defaults to date. Must be >= date." },
    "type": { "type": "string", "enum": ["conference", "symposium", "workshop", "webinar", "seminar", "forum", "summit", "masterclass", "roundtable", "showcase", "week"] },
    "desc": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "pattern": "^https?://", "description": "Optional; official event/registration page." },
    "verified": { "type": "boolean", "description": "true only after a maintainer confirms URL + dates." }
  }
}
