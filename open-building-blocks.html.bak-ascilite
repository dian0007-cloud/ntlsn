<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Open Building Blocks — licence-cleared resources & embeds · NTLSN</title>
<meta name="description" content="Creative-Commons teaching & learning resources you can legally embed, link, harvest or adapt — each with its exact licence and what it permits. Plus a CSP-safe video-embed code generator. Verified June 2026.">
<style>
  :root{
    --navy:#0A1628;--navy2:#0e1d33;--card:#10223b;--teal:#4ECDC4;--teal-d:#2f9e96;
    --gold:#C9A962;--ink:#e8eef5;--mut:#9fb0c3;--line:#1f3350;
    --green:#5fcf91;--amber:#e6b450;--rose:#e58a78;--blue:#7c9cff;
    --serif:"Iowan Old Style","Palatino Linotype",Palatino,Georgia,"Times New Roman",serif;
    --sans:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--navy);color:var(--ink);font-family:var(--sans);line-height:1.6;font-size:16px;-webkit-font-smoothing:antialiased}
  a{color:var(--teal)}
  .wrap{max-width:1020px;margin:0 auto;padding:34px 22px 80px}
  header.top{display:flex;align-items:center;gap:11px;margin-bottom:30px}
  .logo{width:30px;height:30px;flex:none}
  .brand{font-family:var(--serif);font-weight:600;font-size:18px}
  .brand b{color:var(--teal)}
  .eyebrow{font:700 11px var(--sans);letter-spacing:.18em;text-transform:uppercase;color:var(--teal);margin:0 0 10px}
  h1{font-family:var(--serif);font-weight:600;font-size:clamp(28px,4vw,40px);line-height:1.12;margin:0 0 14px;letter-spacing:.2px}
  .lede{font-size:18px;color:var(--mut);max-width:62ch;margin:0 0 8px}
  .verified{font-size:12.5px;color:var(--mut);margin-top:14px}
  .verified b{color:var(--ink)}

  .rule{display:flex;gap:12px;align-items:flex-start;background:linear-gradient(180deg,#13294780,#10223b);border:1px solid var(--line);border-left:3px solid var(--gold);border-radius:4px 13px 13px 13px;padding:15px 18px;margin:26px 0 12px}
  .rule svg{flex:none;width:19px;height:19px;color:var(--gold);margin-top:2px}
  .rule p{margin:0;font-size:14.5px}
  .rule b{color:#f0e3c4}

  h2{font-family:var(--serif);font-weight:600;font-size:23px;margin:40px 0 4px;letter-spacing:.2px}
  .sub{color:var(--mut);font-size:14px;margin:0 0 18px}

  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:14px}
  .res{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:16px 16px 14px;display:flex;flex-direction:column;gap:9px}
  .res h3{margin:0;font-size:16px;font-weight:650}
  .res h3 a{color:var(--ink);text-decoration:none}
  .res h3 a:hover{color:var(--teal)}
  .res .desc{font-size:13px;color:var(--mut);margin:0;flex:1}
  .chips{display:flex;flex-wrap:wrap;gap:6px}
  .chip{font:600 11px var(--sans);letter-spacing:.02em;padding:3px 8px;border-radius:6px;border:1px solid}
  .lic-by{color:#0c1b12;background:var(--green);border-color:var(--green)}
  .lic-sa{color:#06201d;background:var(--teal);border-color:var(--teal)}
  .lic-nc{color:#241c06;background:var(--amber);border-color:var(--amber)}
  .lic-no{color:#2a110b;background:var(--rose);border-color:var(--rose)}
  .perm{display:flex;flex-wrap:wrap;gap:5px;margin-top:1px}
  .perm span{font:600 10.5px var(--sans);text-transform:uppercase;letter-spacing:.05em;color:var(--mut);border:1px solid var(--line);border-radius:5px;padding:2px 6px}
  .perm span.yes{color:var(--teal);border-color:#264f4a}
  .perm span.no{color:var(--rose);border-color:#4a2a26;text-decoration:line-through}
  .attrib{font:500 11.5px var(--mono);color:#8fa6bd;background:#0c1a2e;border:1px solid var(--line);border-radius:7px;padding:6px 9px;word-break:break-word}

  /* embed generator */
  .tool{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:20px;margin-top:6px}
  .tool label{display:block;font:600 12px var(--sans);letter-spacing:.03em;color:var(--mut);text-transform:uppercase;margin-bottom:7px}
  .tool input[type=text]{width:100%;font:inherit;font-size:15px;color:var(--ink);background:var(--navy);border:1px solid var(--line);border-radius:10px;padding:11px 13px;outline:none}
  .tool input:focus{border-color:var(--teal);box-shadow:0 0 0 3px #4ecdc426}
  .out{margin-top:15px;display:none}
  .out.on{display:block}
  .badge{display:inline-flex;align-items:center;gap:6px;font:600 12px var(--sans);padding:4px 9px;border-radius:7px;margin-bottom:10px}
  textarea.code{width:100%;min-height:96px;font:500 12.5px var(--mono);color:#cfe9e5;background:var(--navy);border:1px solid var(--line);border-radius:10px;padding:11px 13px;resize:vertical;outline:none}
  .row{display:flex;gap:9px;flex-wrap:wrap;align-items:center;margin-top:10px}
  .btn{font:600 13px var(--sans);border-radius:9px;padding:9px 14px;cursor:pointer;border:1px solid var(--line);background:transparent;color:var(--ink);transition:.15s}
  .btn:hover{border-color:var(--teal);color:var(--teal)}
  .btn.primary{background:var(--teal);color:#06201d;border-color:var(--teal)}
  .btn.primary:hover{background:#6bd8d0;color:#06201d}
  .note{font-size:12.5px;color:var(--mut);margin-top:11px}
  .note b{color:var(--ink)}
  .preview{margin-top:13px}
  .frame{position:relative;width:100%;padding-top:56.25%;border-radius:10px;overflow:hidden;border:1px solid var(--line);background:#000}
  .frame iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
  .err{color:var(--rose);font-size:13px;margin-top:9px;display:none}

  .foot{margin-top:46px;padding-top:20px;border-top:1px solid var(--line);font-size:12.5px;color:var(--mut)}
  .foot a{color:var(--mut)}
  .back{display:inline-flex;align-items:center;gap:6px;color:var(--teal);text-decoration:none;font-size:14px;font-weight:600;margin-bottom:22px}
  .back:hover{text-decoration:underline}
</style>
</head>
<body>
<div class="wrap">
  <a class="back" href="/">‹ NTLSN.com</a>
  <header class="top">
    <svg class="logo" viewBox="0 0 36 36" fill="none" aria-hidden="true"><circle cx="18" cy="18" r="16.5" stroke="#4ECDC4" stroke-width="1.4" opacity=".4"/><circle cx="18" cy="18" r="4" fill="#4ECDC4"/><g stroke="#4ECDC4" stroke-width="1.2"><line x1="18" y1="14" x2="18" y2="6"/><line x1="22" y1="18" x2="30" y2="18"/><line x1="18" y1="22" x2="18" y2="30"/><line x1="14" y1="18" x2="6" y2="18"/></g></svg>
    <div class="brand">NTLSN<b>.com</b></div>
  </header>

  <p class="eyebrow">◇ Open building blocks</p>
  <h1>What you can legally build on.</h1>
  <p class="lede">Creative-Commons teaching &amp; learning resources you can <b style="color:var(--ink)">embed, link, harvest or adapt</b> — each with its exact licence and what it permits — plus a video-embed code generator that runs entirely in your browser.</p>
  <p class="verified">Licences verified <b>June 2026</b> against primary sources, with adversarial fact-checking. Always re-confirm before a public launch — licences and counts drift.</p>

  <div class="rule">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4"/><path d="M12 17h.01"/><circle cx="12" cy="12" r="9"/></svg>
    <p><b>The one rule that governs everything:</b> a platform's or repository's licence does <b>not</b> cover third-party or embedded media inside it. <b>Embedding and deep-linking are always safe;</b> redistributing or adapting needs a per-item licence check — screen each item for an "all rights reserved" or "unless otherwise noted" notice first.</p>
  </div>

  <h2>Resources you can build on</h2>
  <p class="sub">Verified open sources, most-open first. <span style="color:var(--green)">●</span> reusable · <span style="color:var(--amber)">●</span> non-commercial only · <span style="color:var(--rose)">●</span> embed/link only.</p>
  <div class="grid" id="resGrid"></div>

  <h2>Embed a video — correctly</h2>
  <p class="sub">Paste a YouTube or Vimeo link. This builds the responsive embed code in your browser (no data leaves this page) and reminds you of the licence + attribution rules.</p>
  <div class="tool">
    <label for="vurl">YouTube or Vimeo URL</label>
    <input type="text" id="vurl" placeholder="https://www.youtube.com/watch?v=…  or  https://vimeo.com/…" autocomplete="off" spellcheck="false">
    <div class="row">
      <button class="btn primary" id="genBtn">Build embed code</button>
      <button class="btn" id="prevBtn" style="display:none">Preview ▸</button>
    </div>
    <div class="err" id="vErr"></div>
    <div class="out" id="vOut">
      <div class="badge" id="vBadge"></div>
      <label for="vcode" style="margin-top:4px">Responsive embed code — copy into your page</label>
      <textarea class="code" id="vcode" readonly></textarea>
      <div class="row"><button class="btn" id="copyBtn">Copy code</button></div>
      <div class="note" id="vNote"></div>
      <div class="preview" id="vPreview"></div>
    </div>
  </div>

  <h2>Before you reuse — the checklist</h2>
  <div class="grid">
    <div class="res"><h3>① Confirm the licence on the item itself</h3><p class="desc">Not the homepage badge — the specific page/video/title. Uploaders mislabel; aggregators carve out third-party media.</p></div>
    <div class="res"><h3>② Embed/link beats re-hosting</h3><p class="desc">Embedding is the lowest-risk path and keeps attribution intact. Re-host only what you've licence-checked.</p></div>
    <div class="res"><h3>③ Carry ShareAlike + attribution</h3><p class="desc">Any adaptation of a -SA source (LTR, MIT OCW, Bates, the CAUT MOOC) must keep the same licence and attribute the source.</p></div>
    <div class="res" style="border-left:3px solid var(--gold)"><h3>🪶 Screen for First Nations content</h3><p class="desc">Indigenous teaching material is custodian-led — <b style="color:var(--ink)">do not auto-integrate</b>, even from a CC-BY-SA corpus. Seek Indigenous governance first (NLA ICIP Protocol).</p></div>
  </div>

  <div class="foot">
    NTLSN — the National Teaching and Learning Support Network · a free, open commons. This page links to and explains third-party open resources; each carries its own licence and attribution, shown above. Nothing here is endorsed by the listed organisations.
  </div>
</div>

<script>
(function(){
  "use strict";
  var RES = [
    {n:"Learning &amp; Teaching Repository", u:"https://ltr.edu.au/", lic:["CC-BY-SA 4.0","lic-sa"],
     perm:[["Embed",1],["Link",1],["Harvest",1],["Adapt",1]],
     d:"The legacy ALTC/OLT corpus — 1,431 Australian higher-ed T&amp;L works. Fully redistributable and adaptable with ShareAlike. The richest open AU source.",
     a:"© Commonwealth of Australia / Universities Australia 2018 · CC BY-SA 4.0"},
    {n:"Universities Australia (AAUT)", u:"https://universitiesaustralia.edu.au/legal/", lic:["CC-BY 4.0","lic-by"],
     perm:[["Link",1],["Adapt",1],["Redistribute",1]],
     d:"UA's own site material — including AAUT nomination guidelines, matrices and citation criteria. The only large source you can adapt without a ShareAlike cascade. Confirm per-document (third-party carve-outs).",
     a:"Universities Australia 2014 · CC BY 4.0"},
    {n:"CAUT MOOC — Contemporary Approaches to University Teaching", u:"https://caullt.edu.au/professionallearning/contemporary-approaches-to-university-teaching", lic:["CC-BY-SA","lic-sa"],
     perm:[["Adapt",1],["Share",1]],
     d:"The one openly-licensed CAULLT asset — a foundational teaching MOOC offered to universities to share and adapt (ShareAlike). (Rest of CAULLT is link-only.)",
     a:"CAUT / CAULLT · CC BY-SA"},
    {n:"Teaching in a Digital Age — Tony Bates", u:"https://www.tonybates.ca/teaching-in-a-digital-age/", lic:["CC-BY-NC-SA 4.0","lic-nc"],
     perm:[["Link",1],["Adapt (NC)",1]],
     d:"On-scope open textbook: course models, media selection, MOOCs, OER. Adapt non-commercially with ShareAlike + attribution to A.W. (Tony) Bates.",
     a:"A.W. (Tony) Bates · CC BY-NC-SA 4.0"},
    {n:"MIT OpenCourseWare", u:"https://ocw.mit.edu/", lic:["CC-BY-NC-SA 4.0","lic-nc"],
     perm:[["Embed",1],["Link",1],["Adapt (NC)",1]],
     d:"Unmarked OCW content (the bulk) is CC-BY-NC-SA: embed, link and adapt non-commercially with attribution + ShareAlike. Third-party segments are carved out — screen each.",
     a:"MIT OpenCourseWare · CC BY-NC-SA 4.0"},
    {n:"Open Textbook Library", u:"https://open.umn.edu/opentextbooks/", lic:["Site CC-BY · titles vary","lic-by"],
     perm:[["Link",1],["Harvest",1],["Adapt*",1]],
     d:"1,828 open textbooks. Deep-link &amp; harvest metadata under the site's CC-BY; redistribute/adapt an individual title only after checking that title's own licence.",
     a:"Open Education Network · site CC BY 4.0"},
    {n:"OER Commons (ISKME)", u:"https://oercommons.org/", lic:["Mixed — federate","lic-by"],
     perm:[["Link",1],["Federate",1]],
     d:"100,000+ resources from 350+ providers, heterogeneous licences. Use as a federated gateway / link-out — don't blanket-redistribute.",
     a:"ISKME · per-resource licences vary"},
    {n:"The Carpentries", u:"https://carpentries.org/license/", lic:["CC-BY 4.0","lic-by"],
     perm:[["Embed",1],["Link",1],["Harvest",1],["Adapt",1]],
     d:"Lesson &amp; curriculum materials &mdash; fully reusable (commercial OK), attribution only; code &amp; engine MIT. Check each Incubator/Lab community lesson&rsquo;s own LICENSE.",
     a:"The Carpentries · CC BY 4.0"},
    {n:"TEQSA &mdash; Good Practice &amp; GenAI Hub", u:"https://www.teqsa.gov.au/guides-resources/higher-education-good-practice-hub", lic:["CC-BY 3.0 AU","lic-by"],
     perm:[["Link",1],["Harvest",1],["Adapt",1]],
     d:"The Australian regulator&rsquo;s good-practice &amp; GenAI guidance &mdash; reusable with attribution (TEQSA as author). Commonwealth Coat of Arms excluded.",
     a:"TEQSA · CC BY 3.0 Australia"},
    {n:"ABC Learning Design (UCL)", u:"https://abc-ld.org/license/", lic:["CC-BY-NC-SA 4.0","lic-nc"],
     perm:[["Link",1],["Adapt (NC)",1]],
     d:"The 90-minute curriculum-design method. Adapt/translate non-commercially under ShareAlike; never paywall. Deep-link free.",
     a:"ABC-LD, UCL · CC BY-NC-SA 4.0"},
    {n:"CAST UDL Guidelines", u:"https://udlguidelines.cast.org/", lic:["All rights reserved","lic-no"],
     perm:[["Link",1],["Adapt",0],["Embed",0]],
     d:"The UDL Guidelines are NOT openly licensed &mdash; link only; prior written permission to reproduce. (Only &lsquo;UDL On Campus&rsquo; is CC BY-SA.)",
     a:"© CAST · all rights reserved · link only"},
    {n:"YouTube — Creative Commons videos", u:"https://support.google.com/youtube/answer/2797468", lic:["CC-BY 4.0","lic-by"],
     perm:[["Embed",1],["Adapt (if CC-BY)",1]],
     d:"Videos marked “Creative Commons” are CC-BY 4.0 — embed any video; reuse/adapt only those you confirm are CC-BY (uploaders mislabel). YouTube offers only CC-BY.",
     a:"Attribute the channel · verify CC-BY per video"},
    {n:"Vimeo", u:"https://developer.vimeo.com/api/oembed", lic:["Embed · confirm per video","lic-no"],
     perm:[["Embed",1],["Adapt",0]],
     d:"oEmbed is auth-free &amp; CORS-open, so embeds build client-side — but the payload exposes no licence. Confirm CC status on the video page before any reuse beyond embedding.",
     a:"Attribute the creator · licence not in oEmbed"},
    {n:"TED Talks", u:"https://www.ted.com/about/our-organization/our-policies-terms/ted-talks-usage-policy", lic:["CC-BY-NC-ND 4.0 — embed only","lic-no"],
     perm:[["Embed",1],["Adapt",0],["Re-host",0]],
     d:"Embed/link only on non-commercial sites, with attribution + link back. No clipping, remixing or re-hosting. (TED-Ed is all-rights-reserved — link only.)",
     a:"TED · CC BY-NC-ND 4.0 · non-commercial only"}
  ];
  function el(t,c,h){var e=document.createElement(t);if(c)e.className=c;if(h!=null)e.innerHTML=h;return e;}
  var grid=document.getElementById("resGrid");
  RES.forEach(function(r){
    var c=el("div","res");
    c.appendChild(el("h3",null,'<a href="'+r.u+'" target="_blank" rel="noopener">'+r.n+'</a>'));
    var chips=el("div","chips"); chips.appendChild(el("span","chip "+r.lic[1],r.lic[0])); c.appendChild(chips);
    var perm=el("div","perm");
    r.perm.forEach(function(p){ perm.appendChild(el("span",p[1]?"yes":"no",p[0])); });
    c.appendChild(perm);
    c.appendChild(el("p","desc",r.d));
    c.appendChild(el("div","attrib","Attribute: "+r.a));
    grid.appendChild(c);
  });

  // ---- video embed generator (client-side only, no fetch) ----
  var urlIn=document.getElementById("vurl"), out=document.getElementById("vOut"),
      badge=document.getElementById("vBadge"), code=document.getElementById("vcode"),
      note=document.getElementById("vNote"), prev=document.getElementById("vPreview"),
      errBox=document.getElementById("vErr"), prevBtn=document.getElementById("prevBtn");
  var current=null;

  function parse(u){
    u=(u||"").trim(); if(!u) return null;
    var yt=u.match(/(?:youtube\.com\/(?:watch\?(?:.*&)?v=|embed\/|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{6,})/);
    if(yt) return {kind:"youtube",id:yt[1]};
    var vm=u.match(/vimeo\.com\/(?:video\/)?(\d{6,})/);
    if(vm) return {kind:"vimeo",id:vm[1]};
    if(/^[A-Za-z0-9_-]{11}$/.test(u)) return {kind:"youtube",id:u};
    if(/^\d{6,}$/.test(u)) return {kind:"vimeo",id:u};
    return null;
  }
  function buildCode(p){
    var src = p.kind==="youtube"
      ? "https://www.youtube-nocookie.com/embed/"+p.id
      : "https://player.vimeo.com/video/"+p.id;
    var title = p.kind==="youtube" ? "YouTube video" : "Vimeo video";
    return '<div style="position:relative;width:100%;padding-top:56.25%">\n'
      +'  <iframe src="'+src+'" title="'+title+'" loading="lazy"\n'
      +'    style="position:absolute;inset:0;width:100%;height:100%;border:0"\n'
      +'    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"\n'
      +'    allowfullscreen referrerpolicy="strict-origin-when-cross-origin"></iframe>\n'
      +'</div>';
  }
  function gen(){
    errBox.style.display="none"; out.classList.remove("on"); prev.innerHTML=""; prevBtn.style.display="none";
    var p=parse(urlIn.value);
    if(!p){ errBox.textContent="Couldn't read a YouTube or Vimeo link there. Paste a full video URL."; errBox.style.display="block"; return; }
    current=p;
    code.value=buildCode(p);
    if(p.kind==="youtube"){
      badge.className="badge"; badge.style.background="#12351f"; badge.style.color="var(--green)";
      badge.textContent="YouTube · privacy-enhanced (youtube-nocookie) embed";
      note.innerHTML="<b>Licence check:</b> embedding any YouTube video is fine. To <b>reuse or adapt</b> it, confirm the video is marked <b>Creative Commons (CC-BY 4.0)</b> on YouTube first, and attribute the channel. Using the no-cookie domain keeps it privacy-friendly.";
    } else {
      badge.className="badge"; badge.style.background="#10223b"; badge.style.color="var(--blue)";
      badge.textContent="Vimeo · player embed";
      note.innerHTML="<b>Licence check:</b> Vimeo's oEmbed exposes no licence, so embedding is safe but <b>reuse/adaptation needs the creator's CC licence confirmed on the video page</b>. Attribute the creator.";
    }
    out.classList.add("on"); prevBtn.style.display="inline-block";
  }
  function showPreview(){
    if(!current) return;
    prev.innerHTML='<div class="frame">'+buildCode(current).replace(/^<div[^>]*>|<\/div>$/g,"")+'</div>';
    prevBtn.style.display="none";
  }
  document.getElementById("genBtn").addEventListener("click",gen);
  urlIn.addEventListener("keydown",function(e){ if(e.key==="Enter"){ e.preventDefault(); gen(); } });
  prevBtn.addEventListener("click",showPreview);
  document.getElementById("copyBtn").addEventListener("click",function(){
    code.select(); try{ document.execCommand("copy"); }catch(e){}
    var b=this; var t=b.textContent; b.textContent="Copied ✓"; setTimeout(function(){b.textContent=t;},1400);
  });
})();
</script>
</body>
</html>
